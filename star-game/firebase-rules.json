{
  "rules": {
    "users": {
      ".read": true,
      ".write": false,

      ".indexOn": ["bestStar"],

      "$uid": {
        ".read": true,
        ".write": false
      }
    },

    "enhanceLogs": {
      "$uid": {
        ".read": true,
        ".write": false
      }
    },

    "authSecrets": {
      ".read": false,
      ".write": false
    },

    "config": {
      ".read": false,
      ".write": false
    },

    "sessions": {
      ".read": false,
      ".write": false
    },

    "adminSessions": {
      ".read": false,
      ".write": false
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
